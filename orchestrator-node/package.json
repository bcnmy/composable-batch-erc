    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "@openzeppelin/merkle-tree": "1.0.8",
    "@rhinestone/module-sdk": "0.2.7",
    "async-mutex": "^0.5.0",
    "axios": "^1.9.0",
    "bullmq": "^5.8.2",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "5.1.0",
    "ioredis": "5.6.1",
    "msgpackr": "1.11.2",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0",
    "reflect-metadata": "0.2.2",
    "remeda": "2.21.2",
    "semver": "^7.7.3",
    "typedi": "0.10.0",
    "uuid": "^10.0.0",
    "viem": "^2.45.1",
    "zod": "3.24.3",
    "zod-openapi": "4.2.4"
  },
  "devDependencies": {
    "@biconomy/abstractjs": "^1.0.13",
    "@biomejs/biome": "1.9.4",
    "@types/cors": "^2.8.17",
    "@types/express": "5.0.1",
    "@types/node": "22.15.17",
    "@types/node-fetch": "^2.6.12",
