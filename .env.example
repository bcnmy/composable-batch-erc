# Deployer private key (with 0x prefix)
PRIVATE_KEY=

# RPC URLs (optional — falls back to public RPCs)
RPC_BASE=
RPC_ARBITRUM=
RPC_OPTIMISM=
RPC_POLYGON=
RPC_MAINNET=

# Etherscan V2 API key (one key works for all chains — Base, Arb, OP, Polygon, etc.)
# Get a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
